// Edit user directly from table
async function editUserDirect(userId) {
    currentUserId = userId;
    
    try {
        const response = await fetch(`/admin/api/users/${userId}`, {
            method: 'GET',
            headers: {
                'Accept': 'application/json',
                'Content-Type': 'application/json'
            }
        });
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const result = await response.json();
        
        if (result.success) {
            currentUserData = result.user;
            openEditUserModal(result.user);
        } else {
            showError('Error loading user data for editing');
        }
    } catch (error) {
        console.error('Error loading user data:', error);
        showError('Error loading user data for editing');
    }
}

// Open edit user modal
function openEditUserModal(userData) {
    const modal = document.getElementById('editUserModal');
    
    // Populate form fields
    document.getElementById('editName').value = userData.name || '';
    document.getElementById('editEmail').value = userData.email || '';
    document.getElementById('editAge').value = userData.age || '';
    document.getElementById('editYear').value = userData.year || '';
    document.getElementById('editStudentType').value = userData.studentType || '';
    document.getElementById('editCurriculum').value = userData.curriculum || '';
    document.getElementById('editSchoolName').value = userData.schoolName || '';
    document.getElementById('editStudentPhone').value = userData.studentPhoneNumber || '';
    document.getElementById('editParentPhone').value = userData.parentPhoneNumber || '';
    document.getElementById('editIsActive').checked = userData.isActive || false;
    
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// Close edit user modal
function closeEditUserModal() {
    const modal = document.getElementById('editUserModal');
    modal.classList.remove('show');
    document.body.style.overflow = '';
}

// Save user changes
async function saveUserChanges() {
    if (!currentUserId) {
        showError('No user selected for editing');
        return;
    }

    const form = document.getElementById('editUserForm');
    const formData = new FormData(form);
    
    // Convert FormData to object
    const updateData = {};
    for (let [key, value] of formData.entries()) {
        if (key === 'isActive') {
            updateData[key] = true;
        } else {
            updateData[key] = value;
        }
    }

    try {
        const response = await fetch(`/admin/api/users/${currentUserId}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(updateData)
        });

        const result = await response.json();

        if (result.success) {
            showSuccess('User updated successfully!');
            closeEditUserModal();
            // Reload the page to show updated data
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            showError(result.message || 'Failed to update user');
        }
    } catch (error) {
        console.error('Error updating user:', error);
        showError('An error occurred while updating the user');
    }
}

