                    <strong>Student:</strong> <span id="deleteStudentName"></span><br>
                    <strong>Email:</strong> <span id="deleteStudentEmail"></span>
                </div>
            </div>
        </div>
        <div class="admin-modal-footer">
            <button class="admin-btn admin-btn-secondary" onclick="closeDeleteUserModal()">Cancel</button>
            <button class="admin-btn admin-btn-danger" onclick="confirmDeleteUser()">
                <i class="fas fa-trash me-2"></i>
                Delete Student
            </button>
        </div>
    </div>
</div>

<!-- Bulk Actions Modal -->
<div class="admin-modal-overlay" id="bulkActionsModal">
    <div class="admin-modal">
        <div class="admin-modal-header">
            <h3 class="admin-modal-title">Bulk Actions</h3>
            <button class="admin-modal-close" onclick="closeBulkActionsModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="admin-modal-body">
            <p>You have selected <span id="selectedCount">0</span> students.</p>
            <div class="d-grid gap-2">
                <button class="admin-btn admin-btn-success" onclick="bulkActivate()">
                    <i class="fas fa-check me-2"></i>
                    Approve Selected
                </button>
                <button class="admin-btn admin-btn-warning" onclick="bulkDeactivate()">
                    <i class="fas fa-ban me-2"></i>
