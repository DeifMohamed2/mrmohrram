<!-- User Details Partial -->
<div class="user-details-container">
    <!-- User Profile Section -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="text-center">
                <div class="admin-user-avatar mx-auto mb-3" style="width: 80px; height: 80px; font-size: 32px;">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <h4 class="mb-1"><%= user.name %></h4>
                <p class="text-muted mb-2"><%= user.email %></p>
                <span class="admin-status-badge <%= user.isActive ? 'active' : 'pending' %>">
                    <%= user.isActive ? 'Active' : 'Pending' %>
                </span>
            </div>
        </div>
        <div class="col-md-8">
            <div class="row">
                <div class="col-6 mb-3">
                    <strong>Student Code:</strong><br>
                    <span class="text-muted"><%= user.studentCode %></span>
                </div>
                <div class="col-6 mb-3">
                    <strong>Year:</strong><br>
                    <span class="badge bg-primary"><%= user.year || 'Not Set' %></span>
                </div>
                <div class="col-6 mb-3">
                    <strong>Type:</strong><br>
                    <span class="badge bg-info"><%= user.studentType || 'Not Set' %></span>
                </div>
                <div class="col-6 mb-3">
                    <strong>Progress:</strong><br>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar" style="width: <%= user.totalProgress || 0 %>%"></div>
                    </div>
                    <small class="text-muted"><%= user.totalProgress || 0 %>%</small>
                </div>
                <% if (user.age) { %>
                <div class="col-6 mb-3">
                    <strong>Age:</strong><br>
                    <span class="text-muted"><%= user.age %></span>
                </div>
                <% } %>
                <% if (user.curriculum) { %>
                <div class="col-6 mb-3">
                    <strong>Curriculum:</strong><br>
                    <span class="badge bg-secondary"><%= user.curriculum %></span>
                </div>
                <% } %>
                <% if (user.schoolName) { %>
                <div class="col-6 mb-3">
                    <strong>School:</strong><br>
                    <span class="text-muted"><%= user.schoolName %></span>
                </div>
                <% } %>
                <% if (user.studentPhoneNumber) { %>
                <div class="col-6 mb-3">
                    <strong>Student Phone:</strong><br>
                    <span class="text-muted"><%= user.studentPhoneNumber %></span>
                </div>
                <% } %>
                <% if (user.parentPhoneNumber) { %>
                <div class="col-6 mb-3">
                    <strong>Parent Phone:</strong><br>
                    <span class="text-muted"><%= user.parentPhoneNumber %></span>
                </div>
                <% } %>
                <div class="col-6 mb-3">
                    <strong>Joined:</strong><br>
                    <span class="text-muted"><%= new Date(user.createdAt).toLocaleDateString() %></span>
                </div>
                <div class="col-6 mb-3">
                    <strong>Last Active:</strong><br>
                    <span class="text-muted"><%= user.lastActivity ? new Date(user.lastActivity).toLocaleDateString() : 'Never' %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Progress Section -->
    <% if (progress && progress.length > 0) { %>
    <div class="row mb-4">
        <div class="col-12">
            <h5 class="mb-3">
                <i class="fas fa-chart-line me-2"></i>
                Recent Progress
            </h5>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Week</th>
                            <th>Title</th>
                            <th>Completion</th>
                            <th>Last Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% progress.forEach(prog => { %>
                        <tr>
                            <td><%= prog.week ? prog.week.weekNumber : 'N/A' %></td>
                            <td><%= prog.week ? prog.week.title : 'Unknown Week' %></td>
                            <td>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar" style="width: <%= prog.completionPercentage || 0 %>%"></div>
                                </div>
                                <small><%= prog.completionPercentage || 0 %>%</small>
                            </td>
                            <td><%= new Date(prog.updatedAt).toLocaleDateString() %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center py-3">
                <i class="fas fa-chart-line text-muted mb-2" style="font-size: 2rem;"></i>
                <p class="text-muted">No progress data available</p>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Submissions Section -->
    <% if (submissions && submissions.length > 0) { %>
    <div class="row mb-4">
        <div class="col-12">
            <h5 class="mb-3">
                <i class="fas fa-file-alt me-2"></i>
                Recent Submissions
            </h5>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Week</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Submitted</th>
                            <th>Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% submissions.forEach(submission => { %>
                        <tr>
                            <td><%= submission.week ? submission.week.weekNumber : 'N/A' %></td>
                            <td><%= submission.week ? submission.week.title : 'Unknown Week' %></td>
                            <td>
                                <span class="badge bg-<%= submission.status === 'approved' ? 'success' : submission.status === 'rejected' ? 'danger' : 'warning' %>">
                                    <%= submission.status.charAt(0).toUpperCase() + submission.status.slice(1) %>
                                </span>
                            </td>
                            <td><%= new Date(submission.submittedAt).toLocaleDateString() %></td>
                            <td>
                                <% if (submission.score !== undefined && submission.score !== null) { %>
                                    <%= submission.score %>/<%= submission.totalScore || 100 %>
                                <% } else { %>
                                    <span class="text-muted">Not graded</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center py-3">
                <i class="fas fa-file-alt text-muted mb-2" style="font-size: 2rem;"></i>
                <p class="text-muted">No submissions found</p>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col-12">
            <div class="d-flex gap-2 justify-content-end">
                <button class="admin-btn admin-btn-secondary admin-btn-sm" onclick="closeUserDetailsModal()">
                    <i class="fas fa-times me-2"></i>
                    Close
                </button>
                <button class="admin-btn admin-btn-info admin-btn-sm" onclick="editUserFromModal()">
                    <i class="fas fa-edit me-2"></i>
                    Edit Student
                </button>
                <button class="admin-btn admin-btn-<%= user.isActive ? 'warning' : 'success' %> admin-btn-sm" 
                        onclick="toggleUserStatus('<%= user._id %>', '<%= user.isActive ? 'deactivate' : 'activate' %>')">
                    <i class="fas fa-<%= user.isActive ? 'ban' : 'check' %> me-2"></i>
                    <%= user.isActive ? 'Deactivate' : 'Approve' %>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
.user-details-container {
    padding: 1rem;
}

.admin-user-avatar {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.admin-status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.admin-status-badge.active {
    background-color: #d4edda;
    color: #155724;
}

.admin-status-badge.pending {
    background-color: #fff3cd;
    color: #856404;
}

.admin-status-badge.inactive {
    background-color: #f8d7da;
    color: #721c24;
}

.table th {
    background-color: #f8f9fa;
    border-top: none;
    font-weight: 600;
    font-size: 0.875rem;
    color: #495057;
}

.table td {
    vertical-align: middle;
    font-size: 0.875rem;
}

.progress {
    background-color: #e9ecef;
}

.progress-bar {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.badge {
    font-size: 0.75rem;
    font-weight: 500;
}

.admin-btn {
    padding: 0.375rem 0.75rem;
    border: none;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.admin-btn-sm {
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
}

.admin-btn-primary {
    background-color: #007bff;
    color: white;
}

.admin-btn-primary:hover {
    background-color: #0056b3;
    color: white;
}

.admin-btn-secondary {
    background-color: #6c757d;
    color: white;
}

.admin-btn-secondary:hover {
    background-color: #545b62;
    color: white;
}

.admin-btn-info {
    background-color: #17a2b8;
    color: white;
}

.admin-btn-info:hover {
    background-color: #117a8b;
    color: white;
}

.admin-btn-success {
    background-color: #28a745;
    color: white;
}

.admin-btn-success:hover {
    background-color: #1e7e34;
    color: white;
}

.admin-btn-warning {
    background-color: #ffc107;
    color: #212529;
}

.admin-btn-warning:hover {
    background-color: #e0a800;
    color: #212529;
}

.admin-btn-danger {
    background-color: #dc3545;
    color: white;
}

.admin-btn-danger:hover {
    background-color: #c82333;
    color: white;
}
</style>
